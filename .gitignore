# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
!.yarn/sdks
.npm
.pnpm-store/

# ---------------------------------------------------------------------------
# Next.js
# ---------------------------------------------------------------------------
/.next/
/out/
/build
next-env.d.ts

# ---------------------------------------------------------------------------
# Turbo / Turbopack caches
# ---------------------------------------------------------------------------
.turbo
.swc/

# ---------------------------------------------------------------------------
# TypeScript
# ---------------------------------------------------------------------------
*.tsbuildinfo
.tscache/

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
/coverage
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
.playwright-mcp/
e2e-results/

# ---------------------------------------------------------------------------
# Linting & formatting caches
# ---------------------------------------------------------------------------
.eslintcache
.stylelintcache
.prettiercache

# ---------------------------------------------------------------------------
# Environment files (commit .env.example only)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ---------------------------------------------------------------------------
# Hosting / deploy tooling
# ---------------------------------------------------------------------------
.vercel
.wrangler/
.dev.vars
.netlify
.firebase
.fly/
.cache/

# ---------------------------------------------------------------------------
# Other framework leftovers (Vite/TanStack/Lovable/Nitro)
# ---------------------------------------------------------------------------
dist
dist-ssr
.output
.vinxi
.tanstack/
.nitro
.lovable/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.iml
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
.history/
*.local

# ---------------------------------------------------------------------------
# Claude Code / agents
# ---------------------------------------------------------------------------
.claude/settings.local.json

# ---------------------------------------------------------------------------
# Secrets and credentials
# ---------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
secrets/
credentials.json
serviceAccount*.json

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
tmp/
temp/
*.bak
*.tmp
*.orig
